# ── Appwrite ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Get these from: https://cloud.appwrite.io → your project → Settings

NEXT_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your_database_id_here

# Collection IDs — create one collection per use case (see README for schemas)
NEXT_PUBLIC_APPWRITE_INQUIRIES_COLLECTION_ID=your_inquiries_collection_id
NEXT_PUBLIC_APPWRITE_COURSES_COLLECTION_ID=your_courses_collection_id
NEXT_PUBLIC_APPWRITE_SPONSORSHIP_COLLECTION_ID=your_sponsorship_collection_id
